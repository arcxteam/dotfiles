# ============================================================
# ~/.npmrc — global npm config untuk semua Codespace
# Mencegah timeout/truncated download yang menyebabkan
# error "End of central directory" pada extension install
# ============================================================

# Registry resmi
registry=https://registry.npmjs.org/

# Timeout lebih panjang agar lancar
fetch-timeout=300000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-retries=5

# Nonaktifkan progress bar
progress=false

# Cache lokal yang bersih
cache=/home/codespace/.npm-cache

# Prefer offline hanya jika cache tersedia
prefer-offline=false
